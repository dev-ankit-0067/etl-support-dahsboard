# Application
APP_ENV=production
LOG_LEVEL=INFO
API_PREFIX=/api
CORS_ALLOW_ORIGINS=["https://your-dashboard.example.com"]

# AWS - default credential chain is used when these are unset (recommended in EKS/ECS via IRSA / task roles)
AWS_REGION=us-east-1
# AWS_PROFILE=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# boto3 retry / timeouts
BOTO_MAX_ATTEMPTS=6
BOTO_RETRY_MODE=standard
BOTO_CONNECT_TIMEOUT=5
BOTO_READ_TIMEOUT=30

# Cache TTLs (seconds)
CACHE_TTL_SHORT=30
CACHE_TTL_MEDIUM=300
CACHE_TTL_LONG=1800

# Domain filters
GLUE_JOB_NAME_FILTER=
LAMBDA_FUNCTION_TAG_KEY=Project
LAMBDA_FUNCTION_TAG_VALUE=etl-platform
COST_EXPLORER_TAG_KEY=CostCenter
SLA_BREACH_MINUTES=60

# SSM Incident Manager
# SSM_RESPONSE_PLAN_ARN=arn:aws:ssm-incidents::123456789012:response-plan/etl-prod
